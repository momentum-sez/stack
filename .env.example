# ── Required ──────────────────────────────────────────────────────────────────

# Zone admin API token. Keep secret.
AUTH_TOKEN=

# PostgreSQL password.
POSTGRES_PASSWORD=

# ── Zone Identity ─────────────────────────────────────────────────────────────

MEZ_ZONE_ID=org.momentum.mez.zone.your-jurisdiction
MEZ_JURISDICTION=your-jurisdiction
MEZ_PROFILE=digital-financial-center

# ── Kernel Version ────────────────────────────────────────────────────────────

MEZ_VERSION=0.4.44

# ── Signing ───────────────────────────────────────────────────────────────────

# Ed25519 private key (32-byte hex). Generate: openssl rand -hex 32
ZONE_SIGNING_KEY_HEX=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=8080
MEZ_LOG_LEVEL=info

# ── National Adapters (set if your zone.yaml enables them) ────────────────────

# NATIONAL_ID_API_URL=
# NATIONAL_ID_API_KEY=
# COMPANY_REGISTRY_API_URL=
# TAX_AUTHORITY_API_URL=
# CENTRAL_BANK_API_URL=

# ── Corridor Peers (set if your zone.yaml defines them) ──────────────────────

# PEER_AE_DIFC_URL=
# PEER_US_DE_URL=
